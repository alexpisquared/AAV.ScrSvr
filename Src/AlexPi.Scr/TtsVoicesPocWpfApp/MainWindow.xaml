<Window x:Class="TtsVoicesPocWpfApp.MainWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:local="clr-namespace:TtsVoicesPocWpfApp" mc:Ignorable="d" Title="MainWindow" Height="760" Width="736" Background="#1E1E1E">
  <Window.Resources>
    <Style TargetType="Label" >
      <Setter Property="Foreground" Value="#8E8E93"/>
    </Style>

    <Style TargetType="Button" x:Key="MacButton">
      <Setter Property="Background" Value="#323232"/>
      <Setter Property="Foreground" Value="#E0E0E0"/>
      <Setter Property="BorderBrush" Value="#4A4A4A"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Padding" Value="14,6"/>
      <Setter Property="Margin" Value="4"/>
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6" Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" RecognizesAccessKey="True"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="border" Property="Background" Value="#3A3A3A"/>
                <Setter TargetName="border" Property="BorderBrush" Value="#5A5A5A"/>
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="border" Property="Background" Value="#505050"/>
              </Trigger>
              <Trigger Property="IsDefault" Value="True">
                <Setter TargetName="border" Property="Background" Value="#0A84FF"/>
                <Setter TargetName="border" Property="BorderBrush" Value="#409CFF"/>
                <Setter Property="Foreground" Value="#FFFFFF"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
    <Style TargetType="Button" x:Key="MacCloseButton">
      <Setter Property="Width" Value="14"/>
      <Setter Property="Height" Value="14"/>
      <Setter Property="Margin" Value="8"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Ellipse x:Name="dot" Fill="#FF5F57" Width="14" Height="14"/>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="dot" Property="Fill" Value="#FF3B30"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
    <Style TargetType="Button" BasedOn="{StaticResource MacButton}" />
  </Window.Resources>
  <Grid Margin="0 0 0 0">
    <Grid.RowDefinitions>
      <RowDefinition Height="1*"/>
      <RowDefinition Height="0"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>
    <TextBox Margin="12" TextWrapping="Wrap" Text="The operation has completed successfully." x:Name="tbSpeech"
             Background="#2A2A2A" Foreground="#E0E0E0" CaretBrush="#E0E0E0" SelectionBrush="#0A84FF" BorderBrush="#3A3A3A" BorderThickness="1" Padding="8" FontSize="14" FontFamily="SF Pro Text, Segoe UI, sans-serif"/>
    <StackPanel Orientation="Horizontal" Grid.Row="2" Margin="18,0">
      <StackPanel>
        <Label Content="Volume" FontSize="13" VerticalAlignment="Top" Margin="8 0"/>
        <TextBox Margin="7" TextWrapping="Wrap" Text="20" x:Name="tbVolume" Padding="18 5 0 5" FontSize="14" FontFamily="SF Pro Text, Segoe UI, sans-serif" Background="#2A2A2A" Foreground="#00a0f0" CaretBrush="#E0E0E0" SelectionBrush="#0A84FF" BorderBrush="#3A3A3A" BorderThickness="1" />
      </StackPanel>
      <StackPanel >
        <Label Content="Polina"  />
        <Button Content="cheerful"  Tag="Polina.cheerful"   Click="OnSpeak" />
      </StackPanel>
      <StackPanel >
        <Label Content="Ostap"  />
        <Button Content="cheerful"   Tag="Ostap.cheerful"    Click="OnSpeak"/>
      </StackPanel>
      <StackPanel >
        <Label Content="Aria"  />
        <Button Content="cheerful"    Tag="Aria.cheerful"     Click="OnSpeak" Foreground="#0f0"/>
        <Button Content="chat"    Tag="Aria.chat"         Click="OnSpeak"/>
        <Button Content="customerservice"    Tag="Aria.customerservice"         Click="OnSpeak"/>
        <Button Content="narration_professional"    Tag="Aria.narration_professional"         Click="OnSpeak"/>
        <Button Content="newscast_casual"    Tag="Aria.newscast_casual"         Click="OnSpeak"/>
        <Button Content="newscast_formal"    Tag="Aria.newscast_formal"         Click="OnSpeak"/>
        <Button Content="empathetic"    Tag="Aria.empathetic"         Click="OnSpeak"/>
        <Button Content="angry"    Tag="Aria.angry"         Click="OnSpeak" Foreground="#0f0"/>
        <Button Content="sad"    Tag="Aria.sad"         Click="OnSpeak" Foreground="#0f0"/>
        <Button Content="excited"    Tag="Aria.excited"         Click="OnSpeak"/>
        <Button Content="friendly"    Tag="Aria.friendly"         Click="OnSpeak"/>
        <Button Content="terrified"    Tag="Aria.terrified"         Click="OnSpeak" Foreground="#0f0"/>
        <Button Content="shouting"    Tag="Aria.shouting"         Click="OnSpeak" Foreground="#0f0"/>
        <Button Content="unfriendly"    Tag="Aria.unfriendly"         Click="OnSpeak" Foreground="#0f0"/>
        <Button Content="whispering"    Tag="Aria.whispering"         Click="OnSpeak" Foreground="#0f0"/>
        <Button Content="hopeful"    Tag="Aria.hopeful"         Click="OnSpeak" Foreground="#0f0"/>
      </StackPanel>
      <StackPanel >
        <Label Content="Ryan"  />
        <Button Content="cheerful"    Tag="Ryan.cheerful"     Click="OnSpeak"/>
        <Button Content="chat"    Tag="Ryan.chat"         Click="OnSpeak"/>
      </StackPanel>
      <StackPanel >
        <Label Content="Sonia"  />
        <Button Content="cheerful"   Tag="Sonia.cheerful"    Click="OnSpeak"/>
        <Button Content="sad"   Tag="Sonia.sad"        Click="OnSpeak"/>

      </StackPanel>
      <StackPanel >
        <Label Content="Xiaomo"  />
        <Button Content="cheerful"  Tag="Xiaomo.cheerful"   Click="OnSpeak" Foreground="#0f0"/>
        <Button Content="embarrassed"  Tag="Xiaomo.embarrassed"   Click="OnSpeak"/>
        <Button Content="calm"  Tag="Xiaomo.calm"   Click="OnSpeak"/>
        <Button Content="fearful"  Tag="Xiaomo.fearful"   Click="OnSpeak"/>
        <Button Content="disgruntled"  Tag="Xiaomo.disgruntled"   Click="OnSpeak"/>
        <Button Content="serious"  Tag="Xiaomo.serious"   Click="OnSpeak"/>
        <Button Content="angry"  Tag="Xiaomo.angry"   Click="OnSpeak"/>
        <Button Content="sad"  Tag="Xiaomo.sad"   Click="OnSpeak" Foreground="#0f0"/>
        <Button Content="depressed"  Tag="Xiaomo.depressed"   Click="OnSpeak"/>
        <Button Content="affectionate"  Tag="Xiaomo.affectionate"   Click="OnSpeak"/>
        <Button Content="gentle"  Tag="Xiaomo.gentle"   Click="OnSpeak"/>
        <Button Content="envious"  Tag="Xiaomo.envious"   Click="OnSpeak"/>
      </StackPanel>
    </StackPanel>
    <Button VerticalAlignment="Top" HorizontalAlignment="Right" IsCancel="True" Click="OnClose" Style="{StaticResource MacCloseButton}"/>
  </Grid>
</Window>
